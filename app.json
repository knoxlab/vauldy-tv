{
  "expo": {
    "name": "Vauldy TV",
    "slug": "vauldy-tv",
    "version": "0.1.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "scheme": "vauldy-tv",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f1f6f9"
    },
    "ios": {
      "bundleIdentifier": "com.knoxmedia.vauldy.tv"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f1f6f9"
      },
      "package": "com.knoxmedia.vauldy.tv",
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/tv-banner.png",
          "appleTVImages": {
            "icon": "./assets/icon.png"
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "isTV": true
    }
  }
}
